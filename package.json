{
  "name": "iam-ui",
  "version": "1.1.304",
  "scripts": {
    "preinstall": "npx only-allow npm",
    "ng": "ng",
    "build:lib": "ng build lib",
    "build:lib:watch": "ng build lib --watch",
    "start:ui": "ng serve ui --serve-path=/ui/iam/ui/",
    "start:ui:watch": "concurrently 'npm:build:lib:watch' 'npm:start:ui'",
    "start:wc": "ng serve wc --port 4002 --headers Access-Control-Allow-Origin=*",
    "build:ui": "ng build ui --deploy-url=/ui/iam/ui/",
    "build:wc": "ng build wc --deploy-url=/ui/iam/wc/",
    "build": "npm run build:lib && npm run build:ui && npm run build:wc",
    "lint": "npm run build:lib && ng lint",
    "lint:fix": "npm run build:lib && ng lint --fix",
    "lint:ui": "npm run build:lib && ng lint lib && ng lint ui",
    "lint:wc": "npm run build:lib && ng lint lib && ng lint wc",
    "test": "concurrently 'npm:test:unit' 'npm:test:wc:cov' 'npm:test:ui:cov'",
    "test:unit": "jest --testPathPattern=projects --maxWorkers=40%",
    "test:wc:cov": "jest --testPathPattern=\"projects\\/[lib|wc]\" --maxWorkers=40%",
    "test:ui:cov": "jest --testPathPattern=\"projects\\/[lib|ui]\" --maxWorkers=40%",
    "test:cov": "jest --maxWorkers=40% --coverage",
    "e2e:ci": "echo 'There are no e2e tests'",
    "e2e:wc:ci": "echo 'There are no e2e tests'",
    "e2e:ui:ci": "echo 'There are no e2e tests'",
    "postinstall": "husky install .husky",
    "format": "prettier --write --list-different .",
    "check-format": "prettier --check .",
    "pipeline": "npm run check-format && npm run lint && ACCESS_TOKEN=$PIPER_VAULTCREDENTIAL_ACCESS_TOKEN node node_modules/@openmfp/gha-cache/angular.js"
  },
  "dependencies": {
    "@angular/animations": "20.3.12",
    "@angular/cdk": "20.2.12",
    "@angular/common": "20.3.12",
    "@angular/compiler": "20.3.12",
    "@angular/core": "20.3.12",
    "@angular/elements": "20.3.12",
    "@angular/forms": "20.3.12",
    "@angular/localize": "20.3.12",
    "@angular/platform-browser": "20.3.12",
    "@angular/platform-browser-dynamic": "20.3.12",
    "@angular/router": "20.3.12",
    "@apollo/client": "^4.0.9",
    "@fundamental-ngx/cdk": "~0.57.5",
    "@fundamental-ngx/core": "~0.57.5",
    "@fundamental-ngx/datetime-adapter": "~0.57.5",
    "@fundamental-ngx/i18n": "~0.57.5",
    "@fundamental-ngx/platform": "~0.57.5",
    "@luigi-project/client": "^2.25.1",
    "@luigi-project/client-support-angular": "^20.0.1",
    "@ngrx/effects": "20.1.0",
    "@sap-theming/theming-base-content": "~11.32.2",
    "@sentry/angular": "9.28.1",
    "apollo-angular": "^12.1.0",
    "deep-equal": "2.2.3",
    "fundamental-styles": "~0.40.0",
    "graphql": "16.11.0",
    "graphql-sse": "2.5.4",
    "graphql-ws": "5.16.2",
    "lodash": "^4.17.21",
    "rxjs": "7.8.1",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.10",
    "@angular/cli": "20.3.10",
    "@angular/compiler-cli": "20.3.12",
    "@luigi-project/testing-utilities": "2.14.1",
    "@openmfp/config-prettier": "^0.9.2",
    "@openmfp/eslint-config-typescript": "^0.7.7",
    "@openmfp/gha-cache": "^0.5.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/jest": "29.5.12",
    "@types/node": "22.15.31",
    "angular-eslint": "^20.5.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-jest": "^29.1.0",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "jest-jasmine2": "29.7.0",
    "jest-junit": "^16.0.0",
    "jest-mock-extended": "4.0.0",
    "jest-preset-angular": "15.0.3",
    "lint-staged": "15.5.2",
    "ng-mocks": "14.13.5",
    "ng-packagr": "20.3.2",
    "prettier": "^3.5.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.25.0"
  },
  "lint-staged": {
    "*.{ts,css,md,html,json,scss}": "prettier --list-different",
    "*.ts": "eslint --cache"
  },
  "type": "module"
}
